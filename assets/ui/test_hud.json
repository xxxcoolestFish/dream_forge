{
  "type": "FlexLayout",
  "id": "root",
  "rect": [10, 10, 300, 200],
  "direction": "vertical",
  "gap": 4,
  "padding": 8,
  "children": [
    {
      "type": "Panel",
      "id": "title_bar",
      "color": [35, 35, 55, 230]
    },
    {
      "type": "Text",
      "id": "title_text",
      "text": "AI Game Frame — HUD",
      "color": [220, 220, 255]
    },
    {
      "type": "Text",
      "id": "hp_display",
      "text": "HP: 100",
      "color": [255, 200, 100],
      "binding": {
        "target": "text",
        "source": "ecs",
        "path": "Player.hp",
        "format": "HP: {:.0f}"
      }
    },
    {
      "type": "Text",
      "id": "pos_display",
      "text": "Pos: (0, 0)",
      "color": [180, 180, 220],
      "binding": {
        "target": "text",
        "source": "ecs",
        "path": "Player.pos_x",
        "format": "X: {:.0f}"
      }
    },
    {
      "type": "FlexLayout",
      "id": "button_row",
      "direction": "horizontal",
      "justify": "space-between",
      "gap": 8,
      "padding": 0,
      "children": [
        {
          "type": "Button",
          "id": "btn_talk",
          "text": "对话 (E)",
          "color": [55, 75, 110, 255],
          "grow": 1
        },
        {
          "type": "Button",
          "id": "btn_exit",
          "text": "退出",
          "color": [110, 55, 55, 255],
          "grow": 1
        }
      ]
    }
  ]
}
